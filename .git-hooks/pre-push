#!/bin/bash

# STRIDE Security Pre-push Hook
# ST-03.1 + ST-03.2 + ST-03.3 + ST-14.4 (design feedback for .mmd/.yaml/OpenAPI/.md)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

LOG_FILE=".git/hooks/stride-hook.log"
SCORE_FILE=".git/hooks/last-feedback-score"
TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S")

AGENT="stride-agent/index.js"

# Function: Rotate Log
rotate_log() {
    if [ -f "$LOG_FILE" ]; then
        local size=$(wc -c < "$LOG_FILE")
        if [ $size -gt 1048576 ]; then # 1MB
            mv "$LOG_FILE" "${LOG_FILE}.1"
            echo "[$TIMESTAMP] Log rotated (file exceeded 1MB)." > "$LOG_FILE"
        fi
    fi
}

# 1. DEV_MODE Check
if [ "$DEV_MODE" = "true" ]; then
    echo -e "${GREEN}✓ [DEV_MODE] Simulación de análisis completada. No se bloqueará el push.${NC}"
    rotate_log
    echo "[$TIMESTAMP] RESULT: OK (DEV_MODE) | Analyzed: N/A | Threats: None" >> "$LOG_FILE"
    exit 0
fi

# 2. Determine the diff target
if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
    DIFF_REF="HEAD~1"
else
    DIFF_REF="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
fi

# 3. Classify changed files
FILES=$(git diff "$DIFF_REF" --name-only)
RELEVANT_CODE=""
DESIGN_FILES=""

for file in $FILES; do
    [ ! -f "$file" ] && continue
    FILE_SIZE=$(wc -c < "$file")
    [ "$FILE_SIZE" -gt 51200 ] && continue

    if [[ "$file" =~ \.(java|js|ts|py)$ ]]; then
        RELEVANT_CODE="$RELEVANT_CODE $file"
    elif [[ "$file" =~ \.mmd$ ]]; then
        DESIGN_FILES="$DESIGN_FILES $file"
    elif [[ "$file" =~ \.(yaml|yml)$ ]]; then
        # Include if it looks like OpenAPI
        if grep -qiE "^openapi:|^swagger:" "$file" 2>/dev/null; then
            DESIGN_FILES="$DESIGN_FILES $file"
        fi
    elif [[ "$file" =~ \.md$ ]]; then
        if grep -qiE '```mermaid' "$file" 2>/dev/null; then
            DESIGN_FILES="$DESIGN_FILES $file"
        fi
    fi
done

FINAL_EXIT=0

# ── Phase A: STRIDE analysis on code diffs ────────────────────────────────────
if [ -n "$RELEVANT_CODE" ]; then
    echo -e "${BLUE}STRIDE: Analizando cambios de código...${NC}"
    ANALYSIS_RAW=$(git diff "$DIFF_REF" -- $RELEVANT_CODE | node diff-analyzer/index.js 2>&1)
    CODE_EXIT=$?

    rotate_log
    LOG_SUMMARY=$(echo "$ANALYSIS_RAW" | grep "LOG_SUMMARY:" | cut -d' ' -f2-)
    [ -z "$LOG_SUMMARY" ] && LOG_SUMMARY="Alta=0, Media=0, Baja=0"

    RESULT_STR="OK"
    if [ $CODE_EXIT -eq 1 ]; then
        RESULT_STR="BLOCKED"
        FINAL_EXIT=1
    elif [[ "$LOG_SUMMARY" == *"Media="[1-9]* ]] || [[ "$LOG_SUMMARY" == *"Baja="[1-9]* ]]; then
        RESULT_STR="WARNING"
    fi

    echo "[$TIMESTAMP] CODE: $RESULT_STR | Files: $(echo $RELEVANT_CODE | tr '\n' ' ') | Threats: $LOG_SUMMARY" >> "$LOG_FILE"
    echo -e "$ANALYSIS_RAW" | grep -v "LOG_SUMMARY:"
else
    echo "[$TIMESTAMP] CODE: OK (no relevant code files)" >> "$LOG_FILE"
fi

# ── Phase B: Feedback analysis on design files ────────────────────────────────
if [ -n "$DESIGN_FILES" ]; then
    echo -e "${BLUE}STRIDE: Analizando artefactos de diseño (modo feedback)...${NC}"

    for design_file in $DESIGN_FILES; do
        echo -e "${BLUE}  → $design_file${NC}"
        FEEDBACK_OUT=".git/hooks/feedback-$(basename "$design_file" | tr '.' '-').json"

        node "$AGENT" --file "$design_file" --mode feedback \
            --output "$FEEDBACK_OUT" --no-cache 2>&1

        FB_EXIT=$?
        if [ $FB_EXIT -ne 0 ]; then
            echo -e "${YELLOW}[feedback] Advertencia: no se pudo analizar $design_file${NC}"
        fi
    done

    # Check last saved score
    if [ -f "$SCORE_FILE" ]; then
        LAST_SCORE=$(cat "$SCORE_FILE" 2>/dev/null | tr -d '[:space:]')
        if [[ "$LAST_SCORE" =~ ^[0-9]+$ ]] && [ "$LAST_SCORE" -lt 20 ]; then
            echo -e "${YELLOW}[feedback] Score de diseño muy bajo (${LAST_SCORE}/100). Revisa design-feedback.json antes de publicar.${NC}"
        fi
        echo "[$TIMESTAMP] FEEDBACK: score=${LAST_SCORE} | Files: $(echo $DESIGN_FILES | tr '\n' ' ')" >> "$LOG_FILE"
    fi
fi

if [ -z "$RELEVANT_CODE" ] && [ -z "$DESIGN_FILES" ]; then
    rotate_log
    echo "[$TIMESTAMP] RESULT: OK (No relevant files)" >> "$LOG_FILE"
fi

exit $FINAL_EXIT
