{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Combined Security Report Schema",
  "type": "object",
  "required": ["timestamp", "executive_summary", "stride_analysis", "dynamic_validation", "combined_threats"],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "executive_summary": {
      "type": "object",
      "required": ["total_detected", "total_confirmed", "total_unconfirmed", "confirmation_rate_percent", "system_status"],
      "properties": {
        "total_detected": { "type": "integer" },
        "total_confirmed": { "type": "integer" },
        "total_unconfirmed": { "type": "integer" },
        "confirmation_rate_percent": { "type": "number" },
        "system_status": { "type": "string", "enum": ["available", "unavailable_or_skipped"] }
      }
    },
    "stride_analysis": { "type": "object" },
    "dynamic_validation": { "type": "array" },
    "combined_threats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "component", "description", "severity", "confirmed"],
        "properties": {
          "category": { "type": "string" },
          "component": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["Alta", "Media", "Baja"] },
          "confirmed": { "type": ["boolean", "null"] },
          "confirmation_reason": { "type": ["string", "null"] },
          "dynamic_validation": { "type": ["object", "null"] }
        }
      }
    }
  }
}
