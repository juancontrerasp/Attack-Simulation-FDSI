# STRIDE agent environment variables

# Set to true to force offline/mock analysis (CI, unit tests, etc.).
DEV_MODE=true

# Azure OpenAI configuration (required when DEV_MODE=false).
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_VISION_DEPLOYMENT_NAME=gpt-4o