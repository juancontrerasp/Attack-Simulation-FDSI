# STRIDE-Agent — variables de entorno
# Copia este archivo: cp .env.example .env
# Completa los valores reales en .env (nunca subir .env al repositorio)

# ── Modo de ejecución ──────────────────────────────────────────────────────────
# true  → análisis mock offline, sin llamadas a Azure/Ollama (CI, demos, tests)
# false → análisis real con el proveedor configurado en AI_PROVIDER
DEV_MODE=true

# ── Proveedor de IA ────────────────────────────────────────────────────────────
# azure  → Azure OpenAI (requiere configuración AZURE_* abajo)
# ollama → Ollama local (requiere configuración OLLAMA_* abajo)
# mock   → Respuestas predefinidas sin red (equivalente a DEV_MODE=true)
AI_PROVIDER=azure

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
# Modelo para análisis de texto (STRIDE, feedback, OpenAPI, Mermaid)
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
# Modelo para análisis de imágenes — requiere capacidad de visión (gpt-4o o superior)
AZURE_VISION_DEPLOYMENT_NAME=gpt-4o
# Timeout en ms para llamadas a Azure (default: 60000)
AZURE_TIMEOUT_MS=60000

# ── Ollama (alternativa local) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Modelo de texto (ej: llama3.1:8b, qwen3:8b, mistral:7b)
OLLAMA_MODEL=llama3.1:8b
# Modelo de visión para análisis de imágenes (ej: llava:7b, llama3.2-vision)
OLLAMA_VISION_MODEL=llava:7b
