# STRIDE agent environment variables

# Set to true to force offline/mock analysis.
DEV_MODE=true

# AI provider used when DEV_MODE=false.
# Supported values: azure, ollama
AI_PROVIDER=azure

# Azure OpenAI configuration.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_VISION_DEPLOYMENT_NAME=gpt-4o

# Ollama configuration.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_TIMEOUT_MS=300000
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=2048

# Optional cache tuning.
OLLAMA_CONTEXT_CHARS=6000